ref	rCrosshair

float fAlpha
float fTime

begin Function {rCrosshair}

	; Hide item card on crosshair selection end
	if eval IsFormValid rCrosshair == 0 || GetUIFloatAlt "HUDMainMenu\ItemCard\_B42" || (fAlpha = GetUIFloatAlt "HUDMainMenu\ItemCard\_alpha") == 0
		return
	endif

	fTime = (fAlpha / 255) * 0.20
	SetUIFloatGradual "HUDMainMenu\ItemCard\_alpha" fAlpha 0 fTime
	SetUIFloatGradual "HUDMainMenu\ItemCard\CleanBackground\alpha" fAlpha 0 fTime

end